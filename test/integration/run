#!/usr/bin/env bash
# Run all integration tests (need Xvfb + the harness). Each is self-contained.
set -uo pipefail
cd "$(dirname "$0")"
fail=0
for t in *.sh; do
  echo "=== $t ==="
  if ! ./"$t"; then fail=1; fi
done
[ "$fail" = 0 ] && echo "ALL INTEGRATION TESTS PASSED" || echo "SOME INTEGRATION TESTS FAILED"
exit $fail
